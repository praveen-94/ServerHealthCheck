# PowerShell compiled files
*.ps1~
*.psm1~
*.psd1~
*.ps1xml
*.pssc

# Editor / assistant settings
.vscode/
.history/

# Local AI assistant guidance - not part of the shipped tool
CLAUDE.md
.claude/

# Scratch file for composing commit messages (git commit -F commit-msg.txt)
commit-msg.txt

# Logs and outputs.
# Ignore the CONTENTS, not the directory: an excluded directory is never descended into,
# so "logs/" made the "!logs/.gitkeep" re-include impossible and the folder could never
# be committed. Excluding "logs/*" instead leaves the negation able to take effect.
logs/*
!logs/.gitkeep

# Windows/PowerShell temp files
Thumbs.db
ehthumbs.db
Desktop.ini

# Backup files
*.bak
*.tmp

# Module cache
__pycache__/
*.pyc

# Misc
*.DS_Store
*.swp
*.swo
